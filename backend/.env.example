# Database
# For local SQLite, leave DATABASE_URL empty or use:
DATABASE_URL=sqlite:///./conversys_fut.db

# Local admin user used during development
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=redacted@example.com

# Session signing secret. Use a long random value in production.
AUTH_SECRET=change-me-with-a-long-random-secret

# Optional World Cup 2026 schedule import source (openfootball).
WORLD_CUP_YEAR=2026
WORLD_CUP_SYNC_INTERVAL_SECONDS=600
WORLD_CUP_OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup/master/2026--usa/cup.txt
WORLD_CUP_OPENFOOTBALL_FINALS_URL=https://raw.githubusercontent.com/openfootball/worldcup/master/2026--usa/cup_finals.txt

# Fonte secundária de resultados (conferência cruzada). Chave gratuita em https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Gols ao vivo (placar parcial + goleadores em tempo real). Chave gratuita em https://www.api-football.com
API_FOOTBALL_KEY=
API_FOOTBALL_KEY_2=

# Microsoft Entra ID / Microsoft login
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CLIENT_SECRET_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/callback/microsoft

# OpenAI (insights de IA no bolão, opcional). Use modelo leve (gpt-4o-mini).
OPENAI_API_KEY=
